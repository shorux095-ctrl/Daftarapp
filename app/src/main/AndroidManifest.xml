<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Internet ruxsati — kelajakda backup, sync uchun -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".DaftarApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:enableOnBackInvokedCallback="true"
        android:theme="@style/Theme.Daftar.Splash"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden|keyboard|navigation|uiMode|density|fontScale|smallestScreenSize|locale|layoutDirection"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.Daftar.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Hilt + WorkManager integratsiyasi:
            Default WorkManager initializer'ni o'chiramiz (DaftarApplication o'zi
            Configuration.Provider sifatida boshqaradi).
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
        <!-- Eslatma: aniq vaqt alarmi + reboot'dan keyin tiklash -->
        <receiver
            android:name=".core.notify.EslatmaReceiver"
            android:exported="false" />
        <receiver
            android:name=".core.notify.EslatmaBootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Qarz eslatma: har kuni 10:00 aniq alarm (DaftarApplication + EslatmaBootReceiver rejalashtiradi) -->
        <receiver
            android:name=".core.notify.DebtReminderReceiver"
            android:exported="false" />

        <!-- PDF ulashish uchun -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Tezkor qo'shish (widgetdan ochiladi) -->
        <activity
            android:name=".QuickAddActivity"
            android:exported="false"
            android:excludeFromRecents="true"
            android:theme="@style/Theme.Daftar.Transparent"
            android:windowSoftInputMode="adjustResize" />

        <!-- Bosh ekran widgeti -->
        <receiver
            android:name=".DaftarWidget"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/daftar_widget_info" />
        </receiver>

    </application>

</manifest>
